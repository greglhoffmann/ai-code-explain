OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model selection — one API key covers all models.
# "fast" mode (low latency, coding-optimised):
OPENROUTER_FAST_MODEL=poolside/laguna-m.1:free
# "reasoning" mode (higher capability, larger parameter count):
OPENROUTER_REASONING_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Single-model override: set OPENROUTER_MODEL to force a specific model for both modes.
# OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct

# Optional: restrict local filesystem context sandbox to a specific directory
# LOCAL_CONTEXT_SANDBOX_DIR=./
